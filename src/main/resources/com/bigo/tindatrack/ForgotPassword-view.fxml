<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>

<AnchorPane prefHeight="950.0" prefWidth="1500.0" style="-fx-background-color: #F0F4F1;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bigo.tindatrack.Controller.ForgotPasswordController">
   <children>
      <Circle fill="#d1e7d3" layoutX="167.0" layoutY="560.0" opacity="0.35" radius="93.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
      <Circle fill="#d1e7d3" layoutX="1351.0" layoutY="149.0" opacity="0.74" radius="149.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
      <Circle fill="#d1e7d3" layoutX="130.0" layoutY="820.0" opacity="0.38" radius="130.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
      <Label layoutX="672.0" layoutY="163.0" prefHeight="43.0" prefWidth="156.0" text="TindaTrack">
         <font>
            <Font name="Segoe UI Bold" size="30.0" />
         </font>
      </Label>
      <Label layoutX="607.0" layoutY="206.0" prefHeight="18.0" prefWidth="287.0" style="-fx-font-family: 'Segoe UI'; -fx-font-size: 14;" text="Smart Inventory &amp; Expiry Optimization System" textFill="#00000099" />
      <Circle fill="#d1e7d3" layoutX="414.0" layoutY="204.0" opacity="0.2" radius="67.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
      <Circle fill="#d1e7d3" layoutX="1135.0" layoutY="820.0" opacity="0.2" radius="67.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
      <Circle fill="#d1e7d3" layoutX="1392.0" layoutY="514.0" opacity="0.1" radius="67.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
      <Circle fill="#d1e7d3" layoutX="119.0" layoutY="109.0" opacity="0.08" radius="67.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />
      <ImageView fitHeight="110.0" fitWidth="110.0" layoutX="694.0" layoutY="75.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Images/TindaTrackLogo.png" />
         </image>
      </ImageView>
      <StackPane layoutX="541.0" layoutY="259.0" style="-fx-background-color: #eaf3ea;">
         <children>
            <VBox prefWidth="420" style="-fx-background-color: white; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 24, 0, 0, 4); -fx-padding: 28 32 28 32;">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="6">
                     <children>
                        <Label fx:id="backToSignInLink" onMouseClicked="#OnBackToSignInClick" style="-fx-font-family: 'Segoe UI'; -fx-font-size: 13; -fx-text-fill: #555555; -fx-cursor: hand;" text="&lt; Back to Sign In" />
                     </children>
                  </HBox>
                  <HBox alignment="CENTER_LEFT" spacing="14">
                     <VBox.margin>
                        <Insets top="18" />
                     </VBox.margin>
                     <children>
                        <StackPane fx:id="iconBadge" prefHeight="52" prefWidth="52" style="-fx-background-color: #fff8e1; -fx-background-radius: 14;">
                           <children>
                              <FontIcon iconColor="#cd8f15" iconLiteral="mdi2s-shield-check-outline" iconSize="25" />
                           </children>
                        </StackPane>
                        <VBox spacing="2">
                           <children>
                              <Label style="-fx-font-family: 'Segoe UI'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Verify Your Identity" />
                              <Label style="-fx-font-family: 'Segoe UI';                               -fx-font-size: 13;                               -fx-text-fill: #888888;" text="We'll confirm it's really you" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <HBox alignment="TOP_LEFT" spacing="10" style="-fx-background-color: #fffbea; -fx-background-radius: 10; -fx-border-color: #f5d87a; -fx-border-radius: 10; -fx-border-width: 1; -fx-padding: 14 14 14 14;">
                     <VBox.margin>
                        <Insets bottom="4" top="20" />
                     </VBox.margin>
                     <children>
                        <FontIcon iconColor="#c99525" iconLiteral="mdi2l-lightbulb" iconSize="20" />
                        <Label alignment="CENTER" prefHeight="45.0" prefWidth="318.0" style="-fx-font-family: 'Segoe UI'; -fx-font-size: 12.5; -fx-text-fill: #7a5a00;" text="Enter the details you used when you registered. If they match your account, you can set a new password right away" wrapText="true" />
                     </children>
                  </HBox>
                  <Label style="-fx-font-family: 'Segoe UI'; -fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #1a1a1a;" text="Full Name">
                     <VBox.margin>
                        <Insets bottom="6" top="22" />
                     </VBox.margin>
                  </Label>
                  <HBox alignment="CENTER_LEFT" prefHeight="44" style="-fx-background-color: #f3f7f3; -fx-background-radius: 22; -fx-border-color: #dde8dd; -fx-border-radius: 22; -fx-border-width: 1; -fx-padding: 0 14 0 14;">
                     <children>
                        <TextField fx:id="fullNameField" promptText="e.g. Maria Santos" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-family: 'Segoe UI'; -fx-font-size: 13; -fx-text-fill: #333333; -fx-prompt-text-fill: #b0b8b0;" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  <Label style="-fx-font-family: 'Segoe UI'; -fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #1a1a1a;" text="Phone Number">
                     <VBox.margin>
                        <Insets bottom="6" top="14" />
                     </VBox.margin>
                  </Label>
                  <HBox alignment="CENTER_LEFT" prefHeight="44" style="-fx-background-color: #f3f7f3; -fx-background-radius: 22; -fx-border-color: #dde8dd; -fx-border-radius: 22; -fx-border-width: 1; -fx-padding: 0 14 0 14;">
                     <children>
                        <TextField fx:id="phoneField" promptText="e.g. 09171234567" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-family: 'Segoe UI'; -fx-font-size: 13; -fx-text-fill: #333333; -fx-prompt-text-fill: #b0b8b0;" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  <Label style="-fx-font-family: 'Segoe UI'; -fx-font-size: 14; -fx-font-weight: 600; -fx-text-fill: #1a1a1a;" text="Sari-Sari Store Name">
                     <VBox.margin>
                        <Insets bottom="6" top="14" />
                     </VBox.margin>
                  </Label>
                  <HBox alignment="CENTER_LEFT" prefHeight="44" style="-fx-background-color: #f3f7f3; -fx-background-radius: 22; -fx-border-color: #dde8dd; -fx-border-radius: 22; -fx-border-width: 1; -fx-padding: 0 14 0 14;">
                     <children>
                        <TextField fx:id="storeNameField" promptText="e.g. Aling Nena's Sari-Sari Store" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-family: 'Segoe UI'; -fx-font-size: 13; -fx-text-fill: #333333; -fx-prompt-text-fill: #b0b8b0;" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  <Button fx:id="verifyButton" maxWidth="Infinity" onAction="#handleVerifyAndContinue" prefHeight="48" style="-fx-background-color: #e6a817; -fx-background-radius: 28; -fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-size: 15; -fx-font-weight: bold; -fx-cursor: hand;" text="Verify &amp; Continue">
                     <VBox.margin>
                        <Insets top="24" />
                     </VBox.margin>
                  </Button>
                  <HBox alignment="CENTER" spacing="4">
                     <VBox.margin>
                        <Insets top="16" />
                     </VBox.margin>
                     <children>
                        <Label style="-fx-font-family: 'Segoe UI'; -fx-font-size: 13; -fx-text-fill: #555555;" text="Remember your password?" />
                        <Label fx:id="signUpLabel" onMouseClicked="#OnSignInClick" text="Sign In" textFill="#2e8b2e">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</AnchorPane>
